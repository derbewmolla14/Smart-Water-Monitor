<!DOCTYPE html>
<html lang="am">

<head>
    <meta charset="UTF-8">
    <title>Admin - Receipt Manager</title>

    <link rel="stylesheet" href="/CSS/about.css">

    <link rel="icon" href="data:;base64,iVBORw0KGgoAAAAN">
    <link rel="icon" type="image/png" class="headerimg1" href="/images/HydroOS.png">

    <!-- ✅ ADD API URL -->
    <script>
        const API_URL = "https://smart-water-monitor-7kui.onrender.com";
    </script>

    <style>
        .admin-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            padding: 20px;
        }

        .receipt-card {
            background: white;
            padding: 15px;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            text-align: center;
        }

        .receipt-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-group {
            margin-top: 15px;
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        .approve {
            background: #28a745;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }

        .reject {
            background: #dc3545;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 5px;
            cursor: pointer;
        }

        .admin-btn {
            background-color: #28a745;
            color: white;
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            margin: 10px;
        }

        .admin-btn:hover {
            background-color: #218838;
        }
    </style>
</head>

<body style="background: #f0f2f5;">

    <header class="main-header">
        <div class="logo">Admin Dashboard</div>

        <a href="about-app.html" style="color: white; text-decoration: none;">Go to HOME</a>
        <button onclick="adminLogout()" style="margin-left:20px; cursor:pointer;">Logout</button>
    </header>

    <button onclick="downloadUserExcel()" class="admin-btn">
        📥 Download Users List (Excel)
    </button>

    <div class="container">
        <h2>የደረሱ የክፍያ ደረሰኞች</h2>

        <div id="receiptsContainer" class="admin-grid"></div>
    </div>

    <!-- ✅ SOCKET FIX -->
    <script src="https://cdn.socket.io/4.7.5/socket.io.min.js"></script>

    <script>

        // 🔐 Admin Security
        if (localStorage.getItem("isAdminLoggedIn") !== "true") {
            window.location.href = "admin-login.html";
        }

        // ✅ SOCKET CONNECTION (OPTIONAL REAL-TIME UPDATE)
        const socket = io(API_URL, {
            transports: ["websocket", "polling"]
        });

        socket.on("connect", () => {
            console.log("✅ Admin connected:", socket.id);
        });

        socket.on("paymentApproved", () => {
            loadReceipts();
        });

        socket.on("paymentRejected", () => {
            loadReceipts();
        });


        async function loadReceipts() {
            const container = document.getElementById('receiptsContainer');

            try {
                // ✅ FIXED API URL
                const response = await fetch(`${API_URL}/admin/receipts`);
                const receipts = await response.json();

                if (!receipts || receipts.length === 0) {
                    container.innerHTML = "<p style='text-align:center;'>No receipts yet</p>";
                    return;
                }

                container.innerHTML = "";

                receipts.forEach(receipt => {
                    console.log("Image:", receipt.url);

                    const card = `
                        <div class="receipt-card">
                            <img src="${receipt.url}" onclick="window.open(this.src)">
                            <p><strong>User:</strong> ${receipt.username}</p>
                            <p><strong>Service:</strong> ${receipt.serviceName}</p>

                            <div class="btn-group">
                                <button class="approve"
                                    onclick="approvePayment('${receipt._id}', '${receipt.username}', '${receipt.email}', '${receipt.serviceName}')">
                                    Approve
                                </button>

                                <button class="reject"
                                    onclick="rejectPayment('${receipt.serviceName}', '${receipt.username}', '${receipt.email}')">
                                    Reject
                                </button>
                            </div>
                        </div>
                    `;

                    container.innerHTML += card;
                });

            } catch (error) {
                console.error("Load error:", error);
                container.innerHTML = "<p>Server error</p>";
            }
        }


        async function approvePayment(id, username, email, serviceName) {
            if (!confirm(serviceName + " approve?")) return;

            try {
                const response = await fetch(`${API_URL}/admin/approve-payment`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, username, email, serviceName }) // ✅ email added
                });

                const result = await response.json();

                if (result.success) {
                    alert("Approved!");
                    loadReceipts();
                }

            } catch (error) {
                alert("Error!");
            }
        }


        async function rejectPayment(serviceName, username, email) {
            const reason = prompt("Reason?");
            if (!reason) return;

            try {
                const response = await fetch(`${API_URL}/admin/reject-payment`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ serviceName, username, email, reason }) // ✅ email added
                });

                if (response.ok) {
                    alert("Rejected!");
                    loadReceipts();
                }

            } catch (error) {
                alert("Error!");
            }
        }


        function downloadUserExcel() {
            // ✅ FIXED
            window.location.href = `${API_URL}/admin/download-users`;
        }


        function adminLogout() {
            localStorage.removeItem("isAdminLoggedIn");
            window.location.href = "admin-login.html";
        }

        window.onload = loadReceipts;

    </script>

</body>
</html>